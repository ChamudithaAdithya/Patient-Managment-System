        <!-- TITLE -->
        <mxCell id="title" value="Cloud-Based Hospital Management System — AWS Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="1000" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== VPC (Main Container) ==================== -->
