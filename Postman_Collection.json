    {
      "name": "📅 APPOINTMENTS",
      "item": [
        {
          "name": "6a. Get Available Slots",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/appointments/doctor/{{doctor_id}}/available?date={{target_date}}",
              "host": ["{{base_url}}"],
              "path": ["appointments", "doctor", "{{doctor_id}}", "available"],
              "query": [
                { "key": "date", "value": "{{target_date}}" }
              ]
            },
            "description": "All authenticated roles. Returns array of ISO datetime strings for free 30-min slots."
          }
        },
        {
          "name": "6b. [STAFF] Create Appointment (Tharushi → Dr. Lakmal)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
